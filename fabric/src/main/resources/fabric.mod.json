{
    "schemaVersion": 1,
    "id": "colorful_redstone",
    "version": "${version}",
    "name": "Colorful Redstone",
    "description": "Adds colored redstone dust, blocks, torches, repeaters, and comparators.",
    "authors": [
        "Pasuki"
    ],
    "contact": {
        "homepage": "https://fabricmc.net/",
        "sources": "https://github.com/FabricMC/fabric-example-mod"
    },
    "license": "CC0-1.0",
    "icon": "assets/colorful_redstone/icon.png",
    "environment": "*",
    "entrypoints": {
        "main": [
            "de.pasuki.colorful_redstone.fabric.ColorfulRedstoneFabric"
        ],
        "client": [
            "de.pasuki.colorful_redstone.fabric.client.ColorfulRedstoneFabricClient"
        ],
        "fabric-datagen": [
            "de.pasuki.colorful_redstone.fabric.datagen.ColorfulRedstoneDataGenerator"
        ]
    },
    "mixins": [
        "colorful_redstone.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=0.18.4",
        "minecraft": "~1.21.1",
